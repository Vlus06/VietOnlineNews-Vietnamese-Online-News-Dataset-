# Full data is ignored
data/raw/*
data/rawdata/*
data/processed/*

!data/raw/.gitkeep
!data/rawdata/.gitkeep
!data/processed/.gitkeep

# Dashboard cache is allowed because it contains small precomputed EDA artifacts
!data/dashboard_cache/
!data/dashboard_cache/*.json
!data/dashboard_cache/*.parquet

# Large files are ignored globally
*.csv
*.parquet
*.zip
*.gz
*.pkl
*.joblib

# Re-allow dashboard cache parquet after global parquet ignore
!data/dashboard_cache/*.parquet