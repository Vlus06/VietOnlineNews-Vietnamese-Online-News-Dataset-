.git
.gitignore

__pycache__/
*.pyc
*.pyo
*.pyd

.venv/
venv/
env/

.ipynb_checkpoints/

# Ignore full data
data/raw/*
data/rawdata/*
data/processed/*

# Ignore notebooks from Docker image
notebook/
notebooks/

# Ignore large files globally
*.csv
*.parquet
*.zip
*.gz
*.pkl
*.joblib

# Allow dashboard cache for Fast EDA Mode
!data/dashboard_cache/
!data/dashboard_cache/*.json
!data/dashboard_cache/*.parquet

.DS_Store
Thumbs.db
.env